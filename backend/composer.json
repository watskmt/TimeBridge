{
  "name": "timebridge/backend",
  "description": "TimeBridge - Freelance Engineer Time & Project Management API",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.4",
    "laravel/framework": "^11.0",
    "laravel/sanctum": "^4.0",
    "laravel/tinker": "^2.8",
    "spatie/laravel-permission": "^6.4",
    "spatie/laravel-query-builder": "^5.5",
    "barryvdh/laravel-dompdf": "^2.1",
    "moneyphp/money": "^4.0",
    "doctrine/dbal": "^3.7",
    "predis/predis": "^2.2",
    "aws/aws-sdk-php": "^3.282"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5",
    "laravel/pint": "^1.13",
    "laravel/sail": "^1.26",
    "mockery/mockery": "^1.6",
    "spatie/test-time": "^1.3",
"fakerphp/faker": "^1.23"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "scripts": {
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover --ansi"
    ],
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate --ansi"
    ],
    "test": "phpunit",
    "test:feature": "phpunit --filter Feature",
    "test:unit": "phpunit --filter Unit",
    "lint": "pint"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "pestphp/pest-plugin-laravel": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
